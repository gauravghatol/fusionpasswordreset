@{
    ViewData["Title"] = "Login";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card border-0 shadow-lg">
            <div class="card-body p-5">
                <h1 class="display-6 fw-semibold mb-3">Enterprise password reset for Oracle Fusion</h1>
                <p class="lead text-secondary">Secure, auditable, and integrated with Microsoft Entra ID and APIM-backed Oracle APIs.</p>
                <a class="btn btn-primary btn-lg mt-3" asp-controller="Account" asp-action="SignIn">Sign in with Microsoft</a>
            </div>
        </div>
    </div>
</div>
